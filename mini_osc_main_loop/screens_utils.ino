// 1. Writing default Wave grid
void write_wave_grid(){
  // OLED_Display_1.clearDisplay();                    // erase all(0.4ms)
  OLED_Display_1.setTextColor(SH110X_WHITE);        // write in white character

  OLED_Display_1.setCursor(85, 0);                  // Start at top-left corner
  OLED_Display_1.println(F("av    v"));             // 1-st line fixed characters
  OLED_Display_1.drawFastVLine(26, 9, 55, SH110X_WHITE);   // left vertical line
  OLED_Display_1.drawFastVLine(127, 9, 3, SH110X_WHITE);   // right vertical line up
  OLED_Display_1.drawFastVLine(127, 61, 3, SH110X_WHITE);  // right vertical line bottom

  OLED_Display_1.drawFastHLine(24, 9, 7, SH110X_WHITE);    // Max value auxiliary mark
  OLED_Display_1.drawFastHLine(24, 36, 2, SH110X_WHITE);
  OLED_Display_1.drawFastHLine(24, 63, 7, SH110X_WHITE);

  OLED_Display_1.drawFastHLine(51, 9, 3, SH110X_WHITE);    // Max value auxiliary mark
  OLED_Display_1.drawFastHLine(51, 63, 3, SH110X_WHITE);

  OLED_Display_1.drawFastHLine(76, 9, 3, SH110X_WHITE);    // Max value auxiliary mark
  OLED_Display_1.drawFastHLine(76, 63, 3, SH110X_WHITE);

  OLED_Display_1.drawFastHLine(101, 9, 3, SH110X_WHITE);   // Max value auxiliary mark
  OLED_Display_1.drawFastHLine(101, 63, 3, SH110X_WHITE);

  OLED_Display_1.drawFastHLine(123, 9, 5, SH110X_WHITE);   // right side Max value auxiliary mark
  OLED_Display_1.drawFastHLine(123, 63, 5, SH110X_WHITE);

  for (int x = 26; x <= 128; x += 5) {
    OLED_Display_1.drawFastHLine(x, 36, 2, SH110X_WHITE);  // Draw the center line (horizontal line) with a dotted line
  }
  for (int x = (127 - 25); x > 30; x -= 25) {
    for (int y = 10; y < 63; y += 5) {
      OLED_Display_1.drawFastVLine(x, y, 2, SH110X_WHITE); // Draw 3 vertical lines with dotted lines
    }
  }

  OLED_Display_1.display(); // refresh display ram
}

