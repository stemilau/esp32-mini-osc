// 0.1 Show App info at start up
void setup_oled_menu(){
  int16_t x,y;
  uint16_t w,h;
  uint8_t horizontal_cursor;

  I2C_OLED_2.begin(OLED_SDA_2, OLED_SCL_2); // 100000

  if(!OLED_Display_2.begin(0x3C, true)){
    Serial.println(F("OLED1 SH1106 allocation failed"));
    for(;;);
  }

  OLED_Display_2.clearDisplay();
  OLED_Display_2.setTextSize(1);
  OLED_Display_2.cp437(true);                 
  OLED_Display_2.setTextColor(SH110X_WHITE);

  OLED_Display_2.getTextBounds("Mini-Oscilloscope",0,0,&x,&y,&w,&h);
  horizontal_cursor = (SCREEN_WIDTH - w)/2;
  OLED_Display_2.setCursor(horizontal_cursor, 20);
  OLED_Display_2.println(F("Mini-Oscilloscope"));  

  OLED_Display_2.getTextBounds("v1.0",0,0,&x,&y,&w,&h);
  horizontal_cursor = (SCREEN_WIDTH - w)/2;
  OLED_Display_2.setCursor(horizontal_cursor, 35);
  OLED_Display_2.println(F("v1.0")); 

  OLED_Display_2.getTextBounds("github@stemilau",0,0,&x,&y,&w,&h);
  horizontal_cursor = (SCREEN_WIDTH - w)/2;
  OLED_Display_2.setCursor(horizontal_cursor, 50);            
  OLED_Display_2.println(F("github@stemilau"));                
  OLED_Display_2.display();
}

// 0.2 Show Wave logo at start up
void setup_oled_wave(){
  I2C_OLED_1.begin(OLED_SDA_1, OLED_SCL_1);

  if(!OLED_Display_1.begin(0x3C, true)){
    Serial.println(F("OLED2 SH1106 allocation failed"));
    for(;;);
  }
  // Show logo
  wave_image();
}

