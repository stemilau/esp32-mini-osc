void reset_previous_menu(){
  if(menu_page != previous_menu_page){
    OLED_Display_2.fillRect(0, 2, 70, 60, SH110X_BLACK); // reset menu area
    OLED_Display_2.fillRect(122, 53, 5, 8, SH110X_BLACK); // reset arrow right bottom corner
    previous_menu_page = menu_page; // reset previous page
  }
}

