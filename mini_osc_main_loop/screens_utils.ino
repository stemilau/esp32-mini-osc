void write_measurements(String freq, float duty, String av, float vmax, float vmin){
  OLED_Display_2.setCursor(72, 3);
  OLED_Display_2.println(F("Vpp"));
  OLED_Display_2.setCursor(92, 3);
  OLED_Display_2.println(String(vmax - vmin) + "V");

  OLED_Display_2.setCursor(72, 13);
  OLED_Display_2.println(F("F"));
  OLED_Display_2.setCursor(80, 13);
  OLED_Display_2.println(freq);

  OLED_Display_2.setCursor(72, 23);
  OLED_Display_2.println(F("Duty"));
  OLED_Display_2.setCursor(98, 23);
  OLED_Display_2.println(String(duty) + "%");

  OLED_Display_2.setCursor(72, 33);
  OLED_Display_2.println(F("V"));
  OLED_Display_2.setCursor(78, 33);
  OLED_Display_2.write(0x18);
  OLED_Display_2.setCursor(86, 33);
  OLED_Display_2.println(String(vmax) + "V");

  OLED_Display_2.setCursor(72, 43);
  OLED_Display_2.println(F("V"));
  OLED_Display_2.setCursor(78, 43);
  OLED_Display_2.write(0x19);
  OLED_Display_2.setCursor(86, 43);
  OLED_Display_2.println(String(vmin) + "V");

  OLED_Display_2.setCursor(72, 53);
  OLED_Display_2.println(F("Av"));
  OLED_Display_2.setCursor(86, 53);
  OLED_Display_2.println(av);
  
  OLED_Display_2.display();
}

